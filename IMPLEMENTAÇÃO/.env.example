# ===========================================
# VARIÁVEIS DE AMBIENTE - FINANCEIRO INOVA
# ===========================================
# 
# COPIE ESTE ARQUIVO PARA .env E PREENCHA OS VALORES
# NUNCA COMMIT O ARQUIVO .env NO GIT
# ===========================================

# ===========================================
# SEGURANÇA (OBRIGATÓRIO ALTERAR EM PRODUÇÃO)
# ===========================================

# Secret para assinar tokens JWT
# Gere um valor único e seguro, exemplo:
# openssl rand -hex 32
JWT_SECRET=sua-chave-secreta-aqui-mude-isso

# Tempo de expiração do token JWT
# Padrão: 7d (7 dias)
# Outras opções: 1h (1 hora), 24h (24 horas), 30d (30 dias)
JWT_EXPIRES_IN=7d

# ===========================================
# CORS (CONFIGURAR EM PRODUÇÃO)
# ===========================================

# URL do frontend para CORS
# Desenvolvimento: http://localhost:5173
# Produção: URL do seu domínio
FRONTEND_URL=http://localhost:5173

# ===========================================
# DATABASE
# ===========================================

# Caminho para o banco SQLite
# Padrão: ./finance.db (na raiz do projeto)
DATABASE_PATH=./finance.db

# ===========================================
# SENDPULSE (OPCIONAL - WHATSAPP)
# ===========================================

# Cliente ID do SendPulse
SENDPULSE_CLIENT_ID=

# Cliente Secret do SendPulse
SENDPULSE_CLIENT_SECRET=

# ID do template de cobrança
SENDPULSE_TEMPLATE_ID=

# ===========================================
# GEMINI AI (OPCIONAL)
# ===========================================

# API Key do Google Gemini
# Obtida em: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ===========================================
# SERVIDOR
# ===========================================

# Porta do servidor (padrão: 5173)
PORT=5173

# Modo de execução: development ou production
NODE_ENV=development
